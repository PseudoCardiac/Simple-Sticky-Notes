<Window
    x:Class="SimpleStickyNotes.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Simple Sticky Notes">
    
    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop/>
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Click="NewNoteButton_Click" Text="New note" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Click="AddFontFamilyMenuItem_Click" Text="Add font family" />
                <MenuFlyoutItem Click="ImportLocalFontMenuItem_Click" Text="Import local font" />
                <MenuFlyoutSubItem x:Name="RemoveFontMenu" Text="Remove font" />
            </MenuFlyout>
        </Grid.ContextFlyout>

        <ListView
            x:Name="NotesList"
            IsItemClickEnabled="True"
            ItemClick="NotesList_ItemClick"
            Padding="8"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:NoteItem" xmlns:local="using:SimpleStickyNotes">
                    <Grid Padding="12" MinHeight="58">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            MaxLines="2"
                            Text="{x:Bind Preview, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
