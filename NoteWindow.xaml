<Window
    x:Class="SimpleStickyNotes.NoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style x:Name="RootGridFontIconStyle" TargetType="FontIcon">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            </Style>
            <Style x:Name="RootGridTextBoxStyle"  TargetType="TextBox">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            </Style>
        </Grid.Resources>

        <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent" Padding="9 9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="HandleButton"
                Grid.Column="0"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0">
                <FontIcon
                    x:Name="HandleIcon"
                    Glyph="&#xE7C2;" />
            </Button>

            <Button
                x:Name="PinButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Click="PinButton_Click">
                <FontIcon
                    x:Name="PinIcon"
                    Glyph="&#xE718;" />
            </Button>
            
            <Button
                x:Name="ColorButton"
                Grid.Column="2"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0">
                <FontIcon
                    x:Name="ColorIcon"
                    Glyph="&#xE790;" />
                <Button.Flyout>
                    <Flyout ShouldConstrainToRootBounds="False">
                        <ColorPicker x:Name="ColorPicker"
                            ColorSpectrumShape="Ring"
                            IsMoreButtonVisible="False"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="False"
                            IsHexInputVisible="False"
                            ColorChanged="ColorPicker_ColorChanged" />
                    </Flyout>
                </Button.Flyout>
            </Button>
            
            <Border
                x:Name="LockedTitleDragRegion"
                Grid.Column="3"
                Background="Transparent"
                PointerPressed="LockedDragRegion_PointerPressed" />

            <Button
                x:Name="CloseButton"
                Grid.Column="4"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Click="CloseButton_Click">
                <FontIcon
                    x:Name="CloseIcon"
                    Glyph="&#xF78A;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <TextBox
                x:Name="NoteBox"
                AcceptsReturn="True"
                BorderThickness="0"
                FontSize="18"
                Padding="36, 36, 18, 0"
                TextChanged="NoteBox_TextChanged"
                TextWrapping="Wrap"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Top">
                <TextBox.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Click="OpenListMenuItem_Click" Text="노트 목록 열기" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutSubItem x:Name="FontMenu" Text="글꼴" />
                    </MenuFlyout>
                </TextBox.ContextFlyout>
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                </TextBox.Resources>
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Border
                x:Name="LockedBodyDragRegion"
                Background="Transparent"
                Visibility="Collapsed">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Click="OpenListMenuItem_Click" Text="Open note list" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutSubItem x:Name="LockedFontMenu" Text="Font" />
                    </MenuFlyout>
                </Border.ContextFlyout>
            </Border>
        </Grid>

        <Grid Grid.Row="2" x:Name="SliderAndLockGrid" Background="Transparent" Padding="9 9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
        
            <Slider
                x:Name="FontSizeSlider"
                Grid.Column="0"
                Margin="12,0"
                Maximum="144"
                Minimum="24"
                SmallChange="1"
                StepFrequency="1"
                ValueChanged="FontSizeSlider_ValueChanged"
                VerticalAlignment="Center" />

            <Button
                x:Name="LockButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Click="LockButton_Click">
                <FontIcon
                    x:Name="LockIcon"
                    Glyph="&#xE72E;" />
            </Button>
        </Grid>
    </Grid>
</Window>
