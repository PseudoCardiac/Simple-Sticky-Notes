<Window
    x:Class="SimpleStickyNotes.NoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:Name="RootGrid" Background="#EBC91E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent" Padding="9 9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid.Resources>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />

                <SolidColorBrush x:Name="IconColor1" x:Key="TextControlForeground" Color="#1A1A1A"/>
                <SolidColorBrush x:Name="IconColor2" x:Key="TextControlForegroundPointerOver" Color="#1A1A1A"/>
                <SolidColorBrush x:Name="IconColor3" x:Key="TextControlForegroundFocused" Color="#1A1A1A"/>
            </Grid.Resources>

            <Button
                x:Name="PinButton"
                Grid.Column="0"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0"
                Click="PinButton_Click">
                <FontIcon
                    x:Name="PinIcon"
                    Glyph="&#xE718;" />
            </Button>
            
            <Button
                x:Name="ColorButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0">
                <FontIcon
                    x:Name="ColorIcon"
                    Glyph="&#xE790;" />
                <Button.Flyout>
                    <Flyout ShouldConstrainToRootBounds="False">
                        <ColorPicker x:Name="ColorPicker"
                            ColorSpectrumShape="Ring"
                            IsMoreButtonVisible="False"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="False"
                            IsHexInputVisible="False"
                            ColorChanged="ColorPicker_ColorChanged"
                            Color="{x:Bind _note.BackgroundColor}" />
                    </Flyout>
                </Button.Flyout>
            </Button>
            
            <Border
                x:Name="LockedTitleDragRegion"
                Grid.Column="2"
                Background="Transparent"/>

            <Button
                x:Name="CloseButton"
                Grid.Column="3"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0"
                Click="CloseButton_Click">
                <FontIcon
                    x:Name="CloseIcon"
                    Glyph="&#xF78A;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <TextBox
                x:Name="NoteBox"
                Foreground="#FFFFFF"
                AcceptsReturn="True"
                BorderThickness="0"
                FontSize="18"
                Padding="36, 36, 18, 0"
                TextChanged="NoteBox_TextChanged"
                TextWrapping="Wrap"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Top">
                <TextBox.ContextFlyout>
                    <MenuFlyout x:Name="FontMenu"/>
                </TextBox.ContextFlyout>
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    
                    <SolidColorBrush x:Name="TextColor1" x:Key="TextControlForeground" Color="#1A1A1A"/>
                    <SolidColorBrush x:Name="TextColor2" x:Key="TextControlForegroundPointerOver" Color="#1A1A1A"/>
                    <SolidColorBrush x:Name="TextColor3" x:Key="TextControlForegroundFocused" Color="#1A1A1A"/>
                </TextBox.Resources>
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Border
                x:Name="LockedBodyDragRegion"
                Background="Transparent"
                Visibility="Collapsed" />
        </Grid>

        <Grid Grid.Row="2" x:Name="SliderAndLockGrid" Background="Transparent" Padding="9 9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid.Resources>
                <SolidColorBrush x:Name="IconColor4" x:Key="TextControlForeground" Color="#1A1A1A"/>
                <SolidColorBrush x:Name="IconColor5" x:Key="TextControlForegroundPointerOver" Color="#1A1A1A"/>
                <SolidColorBrush x:Name="IconColor6" x:Key="TextControlForegroundFocused" Color="#1A1A1A"/>
            </Grid.Resources>

            <Slider
                x:Name="FontSizeSlider"
                Grid.Column="0"
                Margin="12,0"
                Maximum="144"
                Minimum="24"
                SmallChange="1"
                StepFrequency="1"
                ValueChanged="FontSizeSlider_ValueChanged"
                VerticalAlignment="Center" />

            <Button
                x:Name="LockButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0"
                Click="LockButton_Click">
                <FontIcon
                    x:Name="LockIcon"
                    Glyph="&#xE72E;" />
            </Button>
        </Grid>
    </Grid>
</Window>
