<Window
    x:Class="SimpleStickyNotes.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Simple Sticky Notes">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem x:ConnectionId='2'                             Text="New note" />
            </MenuFlyout>
        </Grid.ContextFlyout>

        <ListView x:ConnectionId='3'
            x:Name="NotesList"
            IsItemClickEnabled="True"
                                           
            Padding="8"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate                             xmlns:local="using:SimpleStickyNotes">
                    <Grid x:ConnectionId='5' Padding="12" MinHeight="58">
                        <TextBlock x:ConnectionId='6'
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            MaxLines="2"
                                                                
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>

