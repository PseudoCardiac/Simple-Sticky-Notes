<Window
    x:Class="SimpleStickyNotes.NoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid>
        <TextBox x:ConnectionId='2'
            x:Name="NoteBox"
            AcceptsReturn="True"
            BorderThickness="0"
            FontSize="18"
            Padding="14,24,14,14"
                                             
            TextWrapping="Wrap"
            VerticalAlignment="Stretch"
            VerticalContentAlignment="Top">
            <TextBox.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:ConnectionId='4'                                Text="Open note list" />
                    <MenuFlyoutItem x:ConnectionId='5'                                 Text="Close memo" />
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem x:ConnectionId='6'
                        x:Name="AlwaysOnTopMenuItem"
                                                         
                        Text="Always on top" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutSubItem x:ConnectionId='7' x:Name="FontMenu" Text="Font" />
                    <MenuFlyoutSubItem x:ConnectionId='8' x:Name="FontSizeMenu" Text="Size" />
                </MenuFlyout>
            </TextBox.ContextFlyout>
        </TextBox>

        <Border x:ConnectionId='3'
            x:Name="DragRegion"
            Height="22"
            VerticalAlignment="Top"
            Background="Transparent" />
    </Grid>
</Window>

