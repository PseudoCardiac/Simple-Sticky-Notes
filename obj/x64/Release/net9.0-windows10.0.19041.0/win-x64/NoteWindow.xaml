<Window x:ConnectionId='1'
    x:Class="SimpleStickyNotes.NoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:ConnectionId='2' x:Name="RootGrid" Background="#EBC91E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:ConnectionId='3' x:Name="TitleBar" Grid.Row="0" Background="Transparent" Padding="9 9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid.Resources>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />

                <SolidColorBrush x:ConnectionId='17' x:Name="IconColor1" x:Key="TextControlForeground" Color="#1A1A1A"/>
                <SolidColorBrush x:ConnectionId='18' x:Name="IconColor2" x:Key="TextControlForegroundPointerOver" Color="#1A1A1A"/>
                <SolidColorBrush x:ConnectionId='19' x:Name="IconColor3" x:Key="TextControlForegroundFocused" Color="#1A1A1A"/>
            </Grid.Resources>

            <Button x:ConnectionId='20'
                x:Name="PinButton"
                Grid.Column="0"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0"
                                       >
                <FontIcon x:ConnectionId='29'
                    x:Name="PinIcon"
                    Glyph="&#xE718;" />
            </Button>
            
            <Button x:ConnectionId='21'
                x:Name="ColorButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0">
                <FontIcon x:ConnectionId='27'
                    x:Name="ColorIcon"
                    Glyph="&#xE790;" />
                <Button.Flyout>
                    <Flyout ShouldConstrainToRootBounds="False">
                        <ColorPicker x:ConnectionId='28' x:Name="ColorPicker"
                            ColorSpectrumShape="Ring"
                            IsMoreButtonVisible="False"
                            IsColorSliderVisible="True"
                            IsColorChannelTextInputVisible="False"
                            IsHexInputVisible="False"
                                                                   
                                                                   />
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button x:ConnectionId='22'
                x:Name="NewButton"
                Grid.Column="2"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0"
                                       >
                <FontIcon x:ConnectionId='26'
                    x:Name="NewIcon"
                    Glyph="&#xE710;" />
            </Button>

            <Border x:ConnectionId='23'
                x:Name="LockedTitleDragRegion"
                Grid.Column="3"
                Background="Transparent"/>

            <Button x:ConnectionId='24'
                x:Name="CloseButton"
                Grid.Column="4"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0"
                                         >
                <FontIcon x:ConnectionId='25'
                    x:Name="CloseIcon"
                    Glyph="&#xF78A;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <TextBox x:ConnectionId='11'
                x:Name="NoteBox"
                                                                 
                                                                 
                                                               
                                                                   
                Foreground="#FFFFFF"
                AcceptsReturn="True"
                BorderThickness="0"
                                                             
                Margin="36, 0, 36, 0"
                Padding="0, 36, 0, 0"
                                                 
                TextWrapping="Wrap"
                VerticalAlignment="Stretch"
                VerticalContentAlignment="Top">
                <TextBox.ContextFlyout>
                    <MenuFlyout x:ConnectionId='13' x:Name="FontMenu" />
                </TextBox.ContextFlyout>
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
                    
                    <SolidColorBrush x:ConnectionId='14' x:Name="TextColor1" x:Key="TextControlForeground" Color="#1A1A1A"/>
                    <SolidColorBrush x:ConnectionId='15' x:Name="TextColor2" x:Key="TextControlForegroundPointerOver" Color="#1A1A1A"/>
                    <SolidColorBrush x:ConnectionId='16' x:Name="TextColor3" x:Key="TextControlForegroundFocused" Color="#1A1A1A"/>
                </TextBox.Resources>
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Border x:ConnectionId='12'
                x:Name="LockedBodyDragRegion"
                Background="Transparent"
                Visibility="Collapsed" />
        </Grid>

        <Grid x:ConnectionId='4' Grid.Row="2" x:Name="SliderAndLockGrid" Background="Transparent" Padding="9 9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid.Resources>
                <SolidColorBrush x:ConnectionId='5' x:Name="IconColor4" x:Key="TextControlForeground" Color="#1A1A1A"/>
                <SolidColorBrush x:ConnectionId='6' x:Name="IconColor5" x:Key="TextControlForegroundPointerOver" Color="#1A1A1A"/>
                <SolidColorBrush x:ConnectionId='7' x:Name="IconColor6" x:Key="TextControlForegroundFocused" Color="#1A1A1A"/>
            </Grid.Resources>

            <Slider x:ConnectionId='8'
                x:Name="FontSizeSlider"
                Grid.Column="0"
                Margin="12,0"
                Maximum="144"
                Minimum="24"
                SmallChange="1"
                StepFrequency="1"
                                                          
                VerticalAlignment="Center" />

            <Button x:ConnectionId='9'
                x:Name="LockButton"
                Grid.Column="1"
                Width="32"
                Height="32"
                Padding="0"
                Background="Transparent"
                Foreground="#1A1A1A"
                BorderThickness="0"
                                        >
                <FontIcon x:ConnectionId='10'
                    x:Name="LockIcon"
                    Glyph="&#xE72E;" />
            </Button>
        </Grid>
    </Grid>
</Window>

